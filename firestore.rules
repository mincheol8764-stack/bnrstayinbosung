rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: config
    // Document ID: main
    // Fields:
    //   - heroImage: string (required, uri)
    //   - philosophyImage: string (required, uri)
    //   - spaceImages: list (required, objects with url, title, desc)
    //   - links: map (required, naver, instagram, address)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - role: string (required, 'admin' or 'user')
    //   - email: string (required, email)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "mincheol8764@gmail.com") ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidConfig(data) {
      return data.heroImage is string && isValidUrl(data.heroImage) &&
             data.philosophyImage is string && isValidUrl(data.philosophyImage) &&
             data.spaceImages is list &&
             data.links is map &&
             data.links.naver is string && isValidUrl(data.links.naver) &&
             data.links.instagram is string && isValidUrl(data.links.instagram) &&
             data.links.address is string;
    }

    // Config Rules
    match /config/main {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() && isValidConfig(request.resource.data);
    }

    // User Rules
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.role == 'user';
      allow update: if isAdmin();
    }
  }
}
